# Домен берётся из переменной APP_DOMAIN (.env).
# Caddy сам получит и продлит TLS-сертификат Let's Encrypt,
# если домен указывает A-записью на этот сервер и открыты порты 80/443.
{$APP_DOMAIN} {
	# Защита входа логином/паролем.
	# Хэш пароля сгенерировать командой:
	#   docker run --rm caddy caddy hash-password --plaintext 'ваш-пароль'
	basic_auth {
		{$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
	}

	# Запросы к API уходят на бэкенд (NestJS).
	handle /api/* {
		reverse_proxy backend:3000
	}

	# Всё остальное — статика React (SPA: любые маршруты -> index.html).
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	encode gzip
}
