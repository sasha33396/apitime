# ─── Вход в приложение ──────────────────────────────────────────────────
# Обычные логин и пароль (без всяких хэшей). Используются на странице входа.
APP_USER=admin
APP_PASSWORD=придумайте_пароль

# ─── Сеть Caddy ─────────────────────────────────────────────────────────
# Имя docker-сети, в которой работает существующий Caddy (reshala-web).
# Узнать: docker network ls. По умолчанию reshala-web_default — менять обычно не нужно.
# CADDY_NETWORK=reshala-web_default

# ─── Аккаунты Timeweb Cloud ─────────────────────────────────────────────
# Токен берётся в панели Timeweb Cloud: «API и Terraform» -> создать токен.
# Можно добавлять сколько угодно аккаунтов: _1_, _2_, _3_ ...
TW_ACCOUNT_1_NAME=Аккаунт 1
TW_ACCOUNT_1_TOKEN=ТОКЕН_ПЕРВОГО_АККАУНТА
TW_ACCOUNT_1_DOMAIN=first-domain.ru

TW_ACCOUNT_2_NAME=Аккаунт 2
TW_ACCOUNT_2_TOKEN=ТОКЕН_ВТОРОГО_АККАУНТА
TW_ACCOUNT_2_DOMAIN=second-domain.ru
