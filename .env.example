# ─── Домен приложения (для Caddy + HTTPS) ───────────────────────────────
# A-запись этого домена должна указывать на IP вашего сервера.
APP_DOMAIN=dns.example.com

# ─── Защита входа (Caddy basic_auth) ────────────────────────────────────
BASIC_AUTH_USER=admin
# Хэш пароля (НЕ сам пароль!). Сгенерировать:
#   docker run --rm caddy caddy hash-password --plaintext 'ваш-пароль'
# Вставьте полученную строку как есть (она начинается с $2a$...).
BASIC_AUTH_HASH=$2a$14$ЗАМЕНИТЕ_ЭТОТ_ХЭШ

# ─── Аккаунты Timeweb Cloud ─────────────────────────────────────────────
# Токен берётся в панели Timeweb Cloud: «API и Terraform» -> создать токен.
# Можно добавлять сколько угодно аккаунтов: _1_, _2_, _3_ ...
TW_ACCOUNT_1_NAME=Аккаунт 1
TW_ACCOUNT_1_TOKEN=ТОКЕН_ПЕРВОГО_АККАУНТА
TW_ACCOUNT_1_DOMAIN=first-domain.ru

TW_ACCOUNT_2_NAME=Аккаунт 2
TW_ACCOUNT_2_TOKEN=ТОКЕН_ВТОРОГО_АККАУНТА
TW_ACCOUNT_2_DOMAIN=second-domain.ru
